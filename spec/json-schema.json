{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/journey-graph/journey-graph/schema/v1",
  "title": "Journey Graph v1",
  "description": "Tool-neutral, LLM-agnostic graph of a journey: nodes (states), edges (actions on elements), branches (divergences), paths (named traversals). See SPEC.md.",
  "type": "object",
  "required": ["schemaVersion", "kind", "legend", "graph", "nodes", "edges"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "journey-graph" },
    "legend": { "type": "string", "minLength": 1 },
    "specRef": { "type": "string" },
    "graph": {
      "type": "object",
      "required": ["id", "title"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^[^/]+/[^/]+$", "description": "<namespace>/<slug>" },
        "title": { "type": "string", "minLength": 1 },
        "domain": { "type": "string" },
        "description": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "entry": { "type": "string" },
        "context": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "sources": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["ref"],
                "additionalProperties": true,
                "properties": {
                  "type": { "type": "string" },
                  "ref": { "type": "string" },
                  "readAt": { "type": "string" }
                }
              }
            },
            "notes": { "type": "string" }
          }
        },
        "extensions": { "type": "object" }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "name"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["start", "state", "terminal"] },
          "name": { "type": "string", "minLength": 1 },
          "locator": { "type": "string" },
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ref"],
              "additionalProperties": false,
              "properties": {
                "ref": { "type": "string", "minLength": 1 },
                "kind": { "type": "string" },
                "note": { "type": "string" },
                "data": { "type": "object" }
              }
            }
          },
          "data": { "type": "object" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "action"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "action": {
            "type": "object",
            "required": ["verb"],
            "additionalProperties": false,
            "properties": {
              "verb": { "type": "string", "minLength": 1 },
              "target": { "type": ["string", "null"] },
              "input": { "type": ["string", "number", "boolean", "null"] }
            }
          },
          "label": { "type": "string" },
          "guards": { "type": "array", "items": { "type": "string" } },
          "branchOf": { "type": ["string", "null"] },
          "data": { "type": "object" }
        }
      }
    },
    "branches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "variants"],
        "additionalProperties": false,
        "properties": {
          "at": { "type": "string", "minLength": 1 },
          "question": { "type": "string" },
          "variants": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["key", "edge", "covered"],
              "additionalProperties": false,
              "properties": {
                "key": { "type": "string", "minLength": 1 },
                "edge": { "type": ["string", "null"] },
                "covered": { "type": "boolean" },
                "ref": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    },
    "paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "nodes"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "nodes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "edges": { "type": "array", "items": { "type": "string" } },
          "outcome": { "type": "string" },
          "ref": { "type": ["string", "null"] }
        }
      }
    }
  }
}
